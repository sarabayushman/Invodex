
## For handshake between SUPABASE and Google OAuth for signing in from google
# Needed by SUPABASE when initializing OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Needed by clouds.google.com
CALLBACK_URL=https://<yourbasename>.supabase.co/auth/v1/callback


## SUPABASE
SITE_URL=https://invodex-app.vercel.app/
REDIRECT_URL=https://invodex-app.vercel.app/login


